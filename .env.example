# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Google Calendar API (Service Account)
GOOGLE_PRIVATE_KEY=""
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_CALENDAR_ID=""

# Domain-wide delegation (Google Workspace only). Set this to the Workspace
# user the service account should impersonate, e.g. the business owner's
# address. Events are then created as that user, so reminder overrides and
# attendee invitations reach them, and the calendar does not need to be
# shared with the service account at all.
#
# Requires the service account's client ID to be authorized in
# admin.google.com > Security > Access and data control > API controls >
# Domain-wide delegation, with scope:
#   https://www.googleapis.com/auth/calendar
#
# Leave empty on consumer Gmail accounts — delegation is Workspace-only, and
# an unauthorized subject makes every calendar call fail with "unauthorized_client".
GOOGLE_IMPERSONATE_USER=""

# Firebase Configuration (for production fallback)
FIREBASE_PROJECT_ID=""
FIREBASE_DATABASE_ID="(default)"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CRM OWNER USER ID (Firebase Auth UID)
CRM_OWNER_USER_ID=

# Resend — sends the "new booking" notification email to the business owner.
# Without this, bookings still save but NO notification email goes out.
# Get a key at https://resend.com/api-keys (starts with "re_").
# The sending domain must also be verified at https://resend.com/domains.
RESEND_API_KEY=""

# Optional overrides. Defaults are noreply@<business email domain> for the
# sender and businessConfig.email for the recipient (src/config/business.ts).
# Set RESEND_FROM_EMAIL if you verified a different domain in Resend, or use
# onboarding@resend.dev to test before your own domain is verified.
RESEND_FROM_EMAIL=""
RESEND_TO_EMAIL=""

